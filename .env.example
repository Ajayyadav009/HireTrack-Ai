# =============================================================================
# HireTrack AI — Environment Variable Reference
#
# HOW TO USE:
#   1. Copy this file: cp .env.example apps/web/.env.local
#   2. Fill in real values (never commit .env.local)
#   3. For production, set variables via Vercel dashboard / AWS Secrets Manager
#
# CONVENTION:
#   - NEXT_PUBLIC_* variables are exposed to the browser bundle
#   - All other variables are server-only
#   - All secrets must come from a secrets manager in production
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================

# Base URL of the web application (no trailing slash)
# Local:      http://localhost:3000
# Staging:    https://staging.hiretrack.ai
# Production: https://app.hiretrack.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment
# Values: development | staging | production
NODE_ENV=development

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string (Prisma format)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/hiretrack_dev?schema=public

# Direct connection URL (used by Prisma for migrations; bypasses connection pooler)
DIRECT_URL=postgresql://postgres:password@localhost:5432/hiretrack_dev?schema=public

# =============================================================================
# AUTHENTICATION — Auth.js v5
# =============================================================================

# Secret used to sign and encrypt session tokens (min 32 random chars)
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_MIN_32_CHARS

# Canonical URL of the Auth.js handler
AUTH_URL=http://localhost:3000

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================

# Google OAuth 2.0
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET

# =============================================================================
# REDIS (Rate limiting, session cache, BullMQ job queue)
# =============================================================================

# Redis connection URL
# Local: redis://localhost:6379
# Upstash (serverless): rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# =============================================================================
# AWS S3 (File storage — resumes, logos, attachments)
# =============================================================================

# AWS credentials (use IAM role in production — avoid access keys)
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# S3 bucket name for file uploads
AWS_S3_BUCKET_NAME=hiretrack-uploads-dev

# CloudFront distribution URL for serving S3 files
# (Optional in dev; required in production for CDN delivery)
NEXT_PUBLIC_CDN_URL=

# =============================================================================
# EMAIL (Resend — https://resend.com)
# =============================================================================

# Resend API key for sending transactional emails
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY

# "From" email address for all outbound emails
# Must be a verified domain in Resend
EMAIL_FROM=HireTrack AI <noreply@hiretrack.ai>

# =============================================================================
# AI (OpenAI)
# =============================================================================

# OpenAI API key for resume scoring, JD generation, and candidate summaries
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry DSN for error tracking (frontend + backend)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Datadog API key (server-side APM + logs)
DATADOG_API_KEY=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable AI features (set to "false" to disable all AI calls in development)
NEXT_PUBLIC_ENABLE_AI=true

# Enable Sentry error reporting
NEXT_PUBLIC_ENABLE_SENTRY=false

# =============================================================================
# STRIPE (Billing — future milestone)
# =============================================================================

STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
